# PlainScape Community Server Configuration
# Copy this file to .env and fill in your values

# Server name shown in the server browser
SERVER_NAME=My PlainScape Server

# Server description shown in the server browser
SERVER_DESCRIPTION=A community PlainScape server

# Port to run the server on (default: 8080)
PORT=4800

# Admin usernames (comma-separated) — these users get access to / commands
ADMIN_USERS=YourUsername

# Patreon access token — required to appear in the server browser at plainscape.world
# PATREON_KEY=

# Demo key — alternative to Patreon key for testing
# DEMO_KEY=

# Optional: set a password to make your server private
# SERVER_PASSWORD=

# Optional: your public IP (auto-detected if not set)
# SERVER_HOST=

# Optional: max players (default: 100)
# MAX_PLAYERS=100

# ── Admin Console ──
# Port for the admin console (default: 4801, localhost only)
# ADMIN_PORT=4801

# Optional: set a password to protect the admin console
# ADMIN_CONSOLE_PASSWORD=

# Optional: Anthropic API key to enable the daily champion rule system
# ANTHROPIC_API_KEY=

# Optional: GitHub token + repo for rule code pushes
# GITHUB_TOKEN=
# GITHUB_REPO=chvolk/PlainScape-Community

# ── Modding ──
# Mark your server as modded in the server browser
# IS_MODDED=false

# ── Timing ──
# UTC offset for your timezone (default: -7 for Phoenix/Arizona, no DST)
# TIMEZONE_UTC_OFFSET=-7

# Hour (0-23) when the daily champion is selected (default: 18 = 6pm)
# CHAMPION_HOUR=18

# Day of week for weekly reset: 0=Sun 1=Mon ... 6=Sat (default: 0 = Sunday)
# RESET_DAY=0

# Hour (0-23) for weekly reset (default: 20 = 8pm)
# RESET_HOUR=20
